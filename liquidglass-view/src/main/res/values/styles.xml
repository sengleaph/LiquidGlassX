<resources>

    <!--
        Reusable GlassView XML styles. Apply with `style="@style/GlassView.Frosted"` on any
        <com.sifu.liquidglass.GlassView> in a layout. Override individual attrs at the call
        site as usual. Kotlin-side, the same presets exist as GlassStyles.Frosted(context) etc.
    -->

    <style name="GlassView">
        <item name="frost">24dp</item>
        <item name="tintColor">#FFFFFF</item>
        <item name="tintAlpha">0.15</item>
        <item name="cornerRadius">28dp</item>
        <item name="edge">0.7</item>
        <item name="contrast">1.0</item>
        <item name="saturation">1.15</item>
        <item name="refraction">0.7</item>
        <item name="curve">1.4</item>
        <item name="dispersion">0.15</item>
        <item name="lightAngle">135</item>
    </style>

    <style name="GlassView.Frosted" />

    <style name="GlassView.Vivid">
        <item name="frost">30dp</item>
        <item name="tintAlpha">0.12</item>
        <item name="cornerRadius">32dp</item>
        <item name="edge">0.85</item>
        <item name="contrast">1.1</item>
        <item name="saturation">1.4</item>
        <item name="refraction">0.9</item>
        <item name="curve">1.6</item>
        <item name="dispersion">0.3</item>
    </style>

    <style name="GlassView.Subtle">
        <item name="frost">16dp</item>
        <item name="tintAlpha">0.08</item>
        <item name="cornerRadius">20dp</item>
        <item name="edge">0.4</item>
        <item name="saturation">1.05</item>
        <item name="refraction">0.3</item>
        <item name="curve">1.0</item>
        <item name="dispersion">0.05</item>
    </style>

    <style name="GlassView.Dark">
        <item name="frost">32dp</item>
        <item name="tintColor">#0A0A12</item>
        <item name="tintAlpha">0.35</item>
        <item name="cornerRadius">36dp</item>
        <item name="edge">0.5</item>
        <item name="contrast">1.05</item>
        <item name="saturation">1.1</item>
        <item name="refraction">0.7</item>
        <item name="curve">1.5</item>
        <item name="dispersion">0.1</item>
    </style>

    <style name="GlassView.Rainbow">
        <item name="frost">28dp</item>
        <item name="tintAlpha">0.1</item>
        <item name="cornerRadius">40dp</item>
        <item name="edge">0.9</item>
        <item name="contrast">1.2</item>
        <item name="saturation">1.3</item>
        <item name="refraction">1.0</item>
        <item name="curve">2.0</item>
        <item name="dispersion">0.6</item>
    </style>

</resources>
