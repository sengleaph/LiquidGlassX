<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- BACKDROP: must come BEFORE the GlassView in XML order -->
    <ImageView
        android:id="@+id/heroImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_app"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- GLASS: sibling AFTER the backdrop -->
    <com.sifu.liquidglass.GlassView
        android:id="@+id/infoCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:padding="20dp"
        app:cornerRadius="32dp"
        app:frost="28dp"
        app:tintColor="#FFFFFF"
        app:tintAlpha="0.12"
        app:edge="0.8"
        app:refraction="0.9"
        app:curve="1.4"
        app:dispersion="0.08"
        app:saturation="1.25"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sunset over Kampot"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:alpha="0.85"
                android:text="Cambodia · March 2026"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

    </com.sifu.liquidglass.GlassView>

</androidx.constraintlayout.widget.ConstraintLayout>