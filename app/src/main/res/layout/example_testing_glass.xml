<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Backdrop: scrolling list. Colorful items give the glass something to blur. -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="120dp"
            android:paddingBottom="140dp" />

        <!-- Hero card: centered, tap to cycle presets. -->
        <com.sifu.liquidglass.GlassView
            android:id="@+id/heroCard"
            android:layout_width="300dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            app:cornerRadius="28dp"
            app:curve="1.4"
            app:dispersion="0.2"
            app:edge="0.75"
            app:frost="40dp"
            app:lightAngle="135"
            app:refraction="0.7"
            app:tintAlpha="0.15"
            app:tintColor="#FFFFFF">

            <TextView
                android:id="@+id/heroLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Liquid Glass"
                android:textColor="#FFFFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/heroHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|bottom"
                android:layout_marginBottom="18dp"
                android:alpha="0.7"
                android:text="tap to cycle presets"
                android:textColor="#FFFFFFFF"
                android:textSize="11sp" />
        </com.sifu.liquidglass.GlassView>

        <!-- Bottom bar: full-width dark glass toolbar sharing the same backdrop. -->
        <com.sifu.liquidglass.GlassView
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_gravity="bottom"
            app:cornerRadius="0dp"
            app:edge="0.5"
            app:frost="36dp"
            app:refraction="0.4"
            app:tintAlpha="0.3"
            app:tintColor="#0A0A12">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:weightSum="4">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="◐"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="♫"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="★"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="⚙"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp" />
            </LinearLayout>
        </com.sifu.liquidglass.GlassView>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
